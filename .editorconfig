root = true

# NOTE: 'max_line_length' is a style guideline reference; not enforced by EditorConfig itself.

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
max_line_length = 88
trim_trailing_whitespace = true

# Auto-generated lockfiles — preserve as-is
[{package-lock.json}]
trim_trailing_whitespace = false

[*.{css,html,svg}]
max_line_length = 120

[*.md]
max_line_length = 120
trim_trailing_whitespace = false

[*.{txt,log}]
trim_trailing_whitespace = false
