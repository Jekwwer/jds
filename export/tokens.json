{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Two layers: `palette` (raw primitives — never consume directly) and `color` (semantic, dark+light modes). Mode-specific paths: `color.dark.fg.1`, `color.light.fg.1`.",

  "palette": {
    "ink": {
      "$description": "Greyscale ramp — 14 steps from `#ffffff` (0) to `#0d1117` (950).",
      "950": { "$value": "#0d1117", "$type": "color" },
      "900": { "$value": "#11161d", "$type": "color" },
      "850": { "$value": "#161b22", "$type": "color" },
      "800": { "$value": "#1c232c", "$type": "color" },
      "700": { "$value": "#242c36", "$type": "color" },
      "600": { "$value": "#2d3743", "$type": "color" },
      "500": { "$value": "#3b4654", "$type": "color" },
      "400": { "$value": "#5a6675", "$type": "color" },
      "300": { "$value": "#8591a0", "$type": "color" },
      "200": { "$value": "#b4bdc9", "$type": "color" },
      "100": { "$value": "#d9dee5", "$type": "color" },
      "50": { "$value": "#eef1f5", "$type": "color" },
      "25": { "$value": "#f7f8fa", "$type": "color" },
      "0": { "$value": "#ffffff", "$type": "color" }
    },
    "accent": {
      "$description": "Syntax-aligned accents — `<hue>` for dark, `<hue>-light` for light (7 hues).",
      "red": {
        "$value": "#e06c75",
        "$type": "color",
        "$description": "Keywords, errors, danger"
      },
      "red-light": {
        "$value": "#c53030",
        "$type": "color",
        "$description": "Darker variant for light-mode contrast"
      },
      "green": {
        "$value": "#98c379",
        "$type": "color",
        "$description": "Strings, success, added"
      },
      "green-light": {
        "$value": "#3d8c40",
        "$type": "color",
        "$description": "Light-mode variant — decorative only"
      },
      "green-text-light": {
        "$value": "#2e7d32",
        "$type": "color",
        "$description": "Light-mode variant — text-safe"
      },
      "yellow": {
        "$value": "#e5c07b",
        "$type": "color",
        "$description": "Classes, warnings, highlight"
      },
      "yellow-light": {
        "$value": "#b8860b",
        "$type": "color",
        "$description": "Light-mode variant — decorative only"
      },
      "yellow-text-light": {
        "$value": "#806600",
        "$type": "color",
        "$description": "Light-mode variant — text-safe"
      },
      "blue": {
        "$value": "#61afef",
        "$type": "color",
        "$description": "Functions, info, primary"
      },
      "blue-light": {
        "$value": "#1e6bb8",
        "$type": "color",
        "$description": "Darker variant for light-mode contrast"
      },
      "purple": {
        "$value": "#c678dd",
        "$type": "color",
        "$description": "Operators, special, accent"
      },
      "purple-light": {
        "$value": "#8a3fa3",
        "$type": "color",
        "$description": "Darker variant for light-mode contrast"
      },
      "cyan": {
        "$value": "#56b6c2",
        "$type": "color",
        "$description": "Built-ins, constants, info"
      },
      "cyan-light": {
        "$value": "#0b7285",
        "$type": "color",
        "$description": "Darker variant for light-mode contrast"
      },
      "orange": {
        "$value": "#d19a66",
        "$type": "color",
        "$description": "Numbers, parameters, attention"
      },
      "orange-light": {
        "$value": "#b7410e",
        "$type": "color",
        "$description": "Darker variant for light-mode contrast"
      }
    }
  },

  "color": {
    "dark": {
      "$description": "Default mode — dark surfaces with saturated accents.",
      "bg": {
        "default": { "$value": "{palette.ink.950}", "$type": "color" },
        "raised": {
          "$value": "{palette.ink.900}",
          "$type": "color",
          "$description": "Cards, panels, headers"
        },
        "sunken": {
          "$value": "#090d13",
          "$type": "color",
          "$description": "Code blocks, wells"
        },
        "hover": { "$value": "{palette.ink.800}", "$type": "color" },
        "active": { "$value": "{palette.ink.700}", "$type": "color" },
        "selected": {
          "$value": "rgba(97, 175, 239, 0.14)",
          "$type": "color",
          "$description": "Selection highlight"
        }
      },
      "fg": {
        "1": {
          "$value": "{palette.ink.50}",
          "$type": "color",
          "$description": "Primary content"
        },
        "2": {
          "$value": "{palette.ink.200}",
          "$type": "color",
          "$description": "Secondary content"
        },
        "3": {
          "$value": "{palette.ink.300}",
          "$type": "color",
          "$description": "Tertiary / labels"
        },
        "4": {
          "$value": "{palette.ink.400}",
          "$type": "color",
          "$description": "Disabled / very low contrast"
        },
        "inverse": {
          "$value": "{palette.ink.950}",
          "$type": "color",
          "$description": "Foreground on bright accent surfaces"
        }
      },
      "border": {
        "default": { "$value": "{palette.ink.700}", "$type": "color" },
        "strong": { "$value": "{palette.ink.500}", "$type": "color" },
        "subtle": { "$value": "{palette.ink.800}", "$type": "color" },
        "focus": { "$value": "{palette.accent.blue}", "$type": "color" }
      },
      "accent": {
        "primary": { "$value": "{palette.accent.blue}", "$type": "color" },
        "primary-bg": { "$value": "rgba(97, 175, 239, 0.12)", "$type": "color" },
        "success": { "$value": "{palette.accent.green}", "$type": "color" },
        "success-bg": { "$value": "rgba(152, 195, 121, 0.12)", "$type": "color" },
        "warning": { "$value": "{palette.accent.yellow}", "$type": "color" },
        "warning-bg": { "$value": "rgba(229, 192, 123, 0.12)", "$type": "color" },
        "danger": { "$value": "{palette.accent.red}", "$type": "color" },
        "danger-bg": { "$value": "rgba(224, 108, 117, 0.12)", "$type": "color" },
        "info": { "$value": "{palette.accent.cyan}", "$type": "color" },
        "info-bg": { "$value": "rgba(86, 182, 194, 0.12)", "$type": "color" },
        "special": { "$value": "{palette.accent.purple}", "$type": "color" },
        "special-bg": { "$value": "rgba(198, 120, 221, 0.12)", "$type": "color" }
      },
      "syntax": {
        "keyword": { "$value": "{palette.accent.red}", "$type": "color" },
        "string": { "$value": "{palette.accent.green}", "$type": "color" },
        "number": { "$value": "{palette.accent.orange}", "$type": "color" },
        "function": { "$value": "{palette.accent.blue}", "$type": "color" },
        "class": { "$value": "{palette.accent.yellow}", "$type": "color" },
        "operator": { "$value": "{palette.accent.purple}", "$type": "color" },
        "builtin": { "$value": "{palette.accent.cyan}", "$type": "color" },
        "comment": { "$value": "{palette.ink.300}", "$type": "color" },
        "punct": { "$value": "{palette.ink.200}", "$type": "color" }
      },
      "scrollbar": {
        "thumb": { "$value": "{palette.ink.700}", "$type": "color" },
        "track": { "$value": "transparent", "$type": "color" }
      }
    },

    "light": {
      "$description": "Light mode — pale surfaces with darker accents for contrast.",
      "bg": {
        "default": { "$value": "{palette.ink.0}", "$type": "color" },
        "raised": {
          "$value": "{palette.ink.25}",
          "$type": "color",
          "$description": "Cards, panels, headers"
        },
        "sunken": {
          "$value": "{palette.ink.50}",
          "$type": "color",
          "$description": "Code blocks, wells"
        },
        "hover": { "$value": "{palette.ink.50}", "$type": "color" },
        "active": { "$value": "{palette.ink.100}", "$type": "color" },
        "selected": {
          "$value": "rgba(30, 107, 184, 0.10)",
          "$type": "color",
          "$description": "Selection highlight"
        }
      },
      "fg": {
        "1": {
          "$value": "{palette.ink.950}",
          "$type": "color",
          "$description": "Primary content"
        },
        "2": {
          "$value": "{palette.ink.600}",
          "$type": "color",
          "$description": "Secondary content"
        },
        "3": {
          "$value": "{palette.ink.400}",
          "$type": "color",
          "$description": "Tertiary / labels"
        },
        "4": {
          "$value": "{palette.ink.300}",
          "$type": "color",
          "$description": "Disabled / very low contrast"
        },
        "inverse": {
          "$value": "{palette.ink.0}",
          "$type": "color",
          "$description": "Foreground on bright accent surfaces"
        }
      },
      "border": {
        "default": { "$value": "{palette.ink.100}", "$type": "color" },
        "strong": { "$value": "{palette.ink.200}", "$type": "color" },
        "subtle": { "$value": "{palette.ink.50}", "$type": "color" },
        "focus": { "$value": "{palette.accent.blue-light}", "$type": "color" }
      },
      "accent": {
        "primary": { "$value": "{palette.accent.blue-light}", "$type": "color" },
        "primary-bg": { "$value": "rgba(30, 107, 184, 0.10)", "$type": "color" },
        "success": { "$value": "{palette.accent.green-text-light}", "$type": "color" },
        "success-bg": { "$value": "rgba(61, 140, 64, 0.10)", "$type": "color" },
        "warning": { "$value": "{palette.accent.yellow-text-light}", "$type": "color" },
        "warning-bg": { "$value": "rgba(184, 134, 11, 0.12)", "$type": "color" },
        "danger": { "$value": "{palette.accent.red-light}", "$type": "color" },
        "danger-bg": { "$value": "rgba(197, 48, 48, 0.10)", "$type": "color" },
        "info": { "$value": "{palette.accent.cyan-light}", "$type": "color" },
        "info-bg": { "$value": "rgba(11, 114, 133, 0.10)", "$type": "color" },
        "special": { "$value": "{palette.accent.purple-light}", "$type": "color" },
        "special-bg": { "$value": "rgba(138, 63, 163, 0.10)", "$type": "color" }
      },
      "syntax": {
        "keyword": { "$value": "{palette.accent.red-light}", "$type": "color" },
        "string": { "$value": "{palette.accent.green-text-light}", "$type": "color" },
        "number": { "$value": "{palette.accent.orange-light}", "$type": "color" },
        "function": { "$value": "{palette.accent.blue-light}", "$type": "color" },
        "class": { "$value": "{palette.accent.yellow-text-light}", "$type": "color" },
        "operator": { "$value": "{palette.accent.purple-light}", "$type": "color" },
        "builtin": { "$value": "{palette.accent.cyan-light}", "$type": "color" },
        "comment": { "$value": "{palette.ink.400}", "$type": "color" },
        "punct": { "$value": "{palette.ink.600}", "$type": "color" }
      },
      "scrollbar": {
        "thumb": { "$value": "{palette.ink.200}", "$type": "color" },
        "track": { "$value": "transparent", "$type": "color" }
      }
    }
  },

  "font-family": {
    "$description": "System font stacks — `sans` (Geist), `mono` (Geist Mono), `display` (alias for sans, used at heavier weights).",
    "sans": {
      "$value": "\"Geist\", ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", system-ui, sans-serif",
      "$type": "fontFamily"
    },
    "mono": {
      "$value": "\"Geist Mono\", ui-monospace, \"SF Mono\", \"JetBrains Mono\", \"Fira Code\", Menlo, Consolas, monospace",
      "$type": "fontFamily"
    },
    "display": {
      "$value": "{font-family.sans}",
      "$type": "fontFamily"
    }
  },

  "font-weight": {
    "$description": "Variable-font weights — 400 / 500 / 600 / 700.",
    "regular": { "$value": 400, "$type": "fontWeight" },
    "medium": { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" },
    "bold": { "$value": 700, "$type": "fontWeight" }
  },

  "font-size": {
    "$description": "Major-third scale (1.25). All values in px.",
    "xs": { "$value": "12px", "$type": "dimension" },
    "sm": { "$value": "13px", "$type": "dimension" },
    "base": { "$value": "15px", "$type": "dimension" },
    "md": { "$value": "17px", "$type": "dimension" },
    "lg": { "$value": "20px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "30px", "$type": "dimension" },
    "3xl": { "$value": "38px", "$type": "dimension" },
    "4xl": { "$value": "48px", "$type": "dimension" },
    "5xl": { "$value": "60px", "$type": "dimension" },
    "6xl": { "$value": "76px", "$type": "dimension" }
  },

  "line-height": {
    "$description": "Line-height ratios — `tight` for headings, `normal` for prose, `code` for monospace blocks.",
    "tight": { "$value": 1.15, "$type": "number" },
    "snug": { "$value": 1.35, "$type": "number" },
    "normal": { "$value": 1.55, "$type": "number" },
    "code": { "$value": 1.65, "$type": "number" }
  },

  "letter-spacing": {
    "$description": "Tracking — `display`/`tight` for headings + compact UI, `normal` for prose, `mono-kbd` for uppercase mono labels.",
    "display": { "$value": "-0.02em", "$type": "dimension" },
    "tight": { "$value": "-0.01em", "$type": "dimension" },
    "normal": { "$value": "0", "$type": "dimension" },
    "mono-kbd": { "$value": "0.02em", "$type": "dimension" }
  },

  "typography": {
    "$description": "Composite typography slots — `h1`–`h5` headings, `body`/`lead`/`caption` prose, `code`/`kbd`/`label` monospace UI text.",
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.display}",
        "fontWeight": "{font-weight.bold}",
        "fontSize": "{font-size.5xl}",
        "lineHeight": "{line-height.tight}",
        "letterSpacing": "{letter-spacing.display}"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.display}",
        "fontWeight": "{font-weight.semibold}",
        "fontSize": "{font-size.3xl}",
        "lineHeight": "{line-height.tight}",
        "letterSpacing": "{letter-spacing.tight}"
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.sans}",
        "fontWeight": "{font-weight.semibold}",
        "fontSize": "{font-size.2xl}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.tight}"
      }
    },
    "h4": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.sans}",
        "fontWeight": "{font-weight.semibold}",
        "fontSize": "{font-size.xl}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.normal}"
      }
    },
    "h5": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.mono}",
        "fontWeight": "{font-weight.medium}",
        "fontSize": "{font-size.sm}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.mono-kbd}",
        "textTransform": "uppercase"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.sans}",
        "fontWeight": "{font-weight.regular}",
        "fontSize": "{font-size.base}",
        "lineHeight": "{line-height.normal}",
        "letterSpacing": "{letter-spacing.normal}"
      }
    },
    "lead": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.sans}",
        "fontWeight": "{font-weight.regular}",
        "fontSize": "{font-size.lg}",
        "lineHeight": "{line-height.normal}",
        "letterSpacing": "{letter-spacing.normal}"
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.sans}",
        "fontWeight": "{font-weight.regular}",
        "fontSize": "{font-size.sm}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.normal}"
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.mono}",
        "fontWeight": "{font-weight.regular}",
        "fontSize": "0.9em",
        "lineHeight": "{line-height.code}",
        "letterSpacing": "{letter-spacing.normal}"
      }
    },
    "kbd": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.mono}",
        "fontWeight": "{font-weight.medium}",
        "fontSize": "{font-size.xs}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.mono-kbd}",
        "textTransform": "uppercase"
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font-family.mono}",
        "fontWeight": "{font-weight.medium}",
        "fontSize": "{font-size.xs}",
        "lineHeight": "{line-height.snug}",
        "letterSpacing": "{letter-spacing.mono-kbd}",
        "textTransform": "uppercase"
      }
    }
  },

  "spacing": {
    "$description": "4px base grid.",
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "7": { "$value": "32px", "$type": "dimension" },
    "8": { "$value": "40px", "$type": "dimension" },
    "9": { "$value": "48px", "$type": "dimension" },
    "10": { "$value": "64px", "$type": "dimension" },
    "11": { "$value": "80px", "$type": "dimension" },
    "12": { "$value": "96px", "$type": "dimension" }
  },

  "radius": {
    "$description": "Corner radii — `xs`/`sm` for chips, `md` (default) for buttons/inputs, `lg` for cards/modals, `xl` for hero surfaces, `full` for pills + scrollbar thumbs.",
    "xs": { "$value": "3px", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "6px", "$type": "dimension" },
    "lg": { "$value": "8px", "$type": "dimension" },
    "xl": { "$value": "12px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "border-width": {
    "$description": "Single 1px width — no other border weights.",
    "default": { "$value": "1px", "$type": "dimension" }
  },

  "shadow": {
    "$description": "Mode-specific shadow scales. Dark mode uses an inset highlight + dark drop; light uses tinted slate drops.",
    "dark": {
      "sm": {
        "$type": "shadow",
        "$value": [
          {
            "color": "rgba(255, 255, 255, 0.03)",
            "offsetX": "0",
            "offsetY": "1px",
            "blur": "0",
            "spread": "0",
            "inset": true
          },
          {
            "color": "rgba(0, 0, 0, 0.5)",
            "offsetX": "0",
            "offsetY": "1px",
            "blur": "2px",
            "spread": "0",
            "inset": false
          }
        ]
      },
      "md": {
        "$type": "shadow",
        "$value": [
          {
            "color": "rgba(255, 255, 255, 0.03)",
            "offsetX": "0",
            "offsetY": "1px",
            "blur": "0",
            "spread": "0",
            "inset": true
          },
          {
            "color": "rgba(0, 0, 0, 0.4)",
            "offsetX": "0",
            "offsetY": "4px",
            "blur": "12px",
            "spread": "0",
            "inset": false
          }
        ]
      },
      "lg": {
        "$type": "shadow",
        "$value": [
          {
            "color": "rgba(255, 255, 255, 0.04)",
            "offsetX": "0",
            "offsetY": "1px",
            "blur": "0",
            "spread": "0",
            "inset": true
          },
          {
            "color": "rgba(0, 0, 0, 0.55)",
            "offsetX": "0",
            "offsetY": "16px",
            "blur": "40px",
            "spread": "0",
            "inset": false
          }
        ]
      },
      "focus": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(97, 175, 239, 0.35)",
          "offsetX": "0",
          "offsetY": "0",
          "blur": "0",
          "spread": "3px",
          "inset": false
        }
      },
      "focus-danger": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(224, 108, 117, 0.35)",
          "offsetX": "0",
          "offsetY": "0",
          "blur": "0",
          "spread": "3px",
          "inset": false
        }
      }
    },
    "light": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(15, 23, 42, 0.06)",
          "offsetX": "0",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "0",
          "inset": false
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(15, 23, 42, 0.08)",
          "offsetX": "0",
          "offsetY": "4px",
          "blur": "12px",
          "spread": "0",
          "inset": false
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(15, 23, 42, 0.14)",
          "offsetX": "0",
          "offsetY": "16px",
          "blur": "40px",
          "spread": "0",
          "inset": false
        }
      },
      "focus": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(30, 107, 184, 0.30)",
          "offsetX": "0",
          "offsetY": "0",
          "blur": "0",
          "spread": "3px",
          "inset": false
        }
      },
      "focus-danger": {
        "$type": "shadow",
        "$value": {
          "color": "rgba(197, 48, 48, 0.30)",
          "offsetX": "0",
          "offsetY": "0",
          "blur": "0",
          "spread": "3px",
          "inset": false
        }
      }
    }
  },

  "z-index": {
    "$description": "Stacking order — `base` < `raised` < `sticky` < `overlay` < `modal` < `toast` < `tooltip`.",
    "base": { "$value": 0, "$type": "number" },
    "raised": { "$value": 10, "$type": "number" },
    "sticky": { "$value": 100, "$type": "number" },
    "overlay": { "$value": 1000, "$type": "number" },
