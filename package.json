{
  "name": "@jekwwer/jds",
  "version": "0.1.0",
  "private": false,
  "description": "Jekwwer Design System — token-driven, dark+light-symmetric design system. CSS variables + utility classes, no JS runtime. Personal scope, used across Jekwwer projects.",
  "keywords": [
    "design-system",
    "design-tokens",
    "tokens",
    "css-variables",
    "theming",
    "dark-mode",
    "light-mode",
    "typography",
    "geist",
    "dtcg",
    "style-dictionary"
  ],
  "homepage": "https://github.com/Jekwwer/jds",
  "bugs": {
    "url": "https://github.com/Jekwwer/jds/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jekwwer/jds.git"
  },
  "license": "MIT",
  "author": {
    "name": "Evgenii Shiliaev",
    "email": "evgenii.shiliaev@jekwwer.com",
    "url": "https://jekwwer.com"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "main": "./dist/tokens.css",
  "style": "./dist/tokens.css",
  "exports": {
    ".": "./dist/tokens.css",
    "./tokens.css": "./dist/tokens.css",
    "./tokens.flat.json": "./dist/tokens.flat.json",
    "./base.css": "./src/base.css",
    "./tokens.json": "./export/tokens.json",
    "./fonts/*": "./fonts/*",
    "./assets/*": "./assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "export/",
    "fonts/",
    "assets/",
    "README.md",
    "NOTICE.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:tokens": "style-dictionary build --config sd.config.mjs",
    "build:labels": "node scripts/build-labels.mjs",
    "build:badges": "node scripts/build-badges.mjs",
    "build": "npm run build:tokens && npm run build:labels && npm run build:badges",
    "clean": "rm -rf dist/ badges/",
    "spell": "cspell . --cache",
    "format": "prettier --check .",
    "format-fix": "prettier --write .",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown",
      "cspell --no-progress --no-summary --no-must-find-files"
    ],
    "src/**/*.css": "stylelint --fix",
    "*.md": "markdownlint-cli2 --fix"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^9.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "style-dictionary": "^4.4.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.1"
  }
}
